{
  "name": "selenium-admin",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrate-sessions.js",
    "migrate:auth": "node migrate-auth.js",
    "db:stats": "node db-utils.js stats",
    "db:cleanup": "node db-utils.js cleanup",
    "db:export": "node db-utils.js export",
    "db:search": "node db-utils.js search",
    "test:db": "node -e \"require('./database').then(db => { console.log('✅ Database connection successful'); db.close(); })\"",
    "test:user-extraction": "node -e \"const db = require('./database'); db.updateSession('test', {username: 'test', avatarSrc: 'test.jpg'}).then(() => { console.log('✅ User info extraction test passed'); db.close(); }).catch(e => { console.error('❌ Test failed:', e); db.close(); })\"",
    "fix:stuck-sessions": "node fix-stuck-sessions.js",
    "setup:bot": "node setup-safeguard-bot.js"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mocha": "11.7.1",
    "prisma": "^6.14.0",
    "selenium-webdriver": "^4.34.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.8.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
